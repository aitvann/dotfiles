#! /usr/bin/env bb
; vim: set ft=clojure:

(require
 '[hypr-current-location :refer [get-data]]
 '[babashka.process :refer [process]]
 '[clojure.java.io :as io])

(defn dirname [path]
  (let [file (io/file path)]
    (if (.exists file)
      (if (.isFile file)
        (.getParent file)
        path)
      path)))

(let [{:keys [location]} (get-data)
      location (dirname location)]
  @(process "foot" "-D" location))

; ; HACK: process won't spawn unless we sleep for a bit. Better then `deref`
; (Thread/sleep 100)
