; Zsh is not required for it to function properly
; Interactive session (`-i`) is not required for it function properly
; But `zsh -ic` is required to make sure persistent session is saved when application is killed
(defn nnn [{:keys [location nvim_pipe fallback]} selection-file]
  @(process {:extra-env {"NNN_PREVIEW_TITLE" "nnn-file-manager-preview"}}
            (System/getenv "TERMINAL")
            "--title=nnn-file-manager"
            "-e"
            (System/getenv "SHELL")
            "-ic"
            (str
             "nnn "
             "-S "
             "-P v "
             (if nvim_pipe (str "-p " selection-file " ") "")
             (if fallback "" location))))

(let [{:keys [nvim_pipe] :as data} (get-data)]
  (kill-current-and-exit "nnn-file-manager" "nnn-file-manager-preview")

  (if (not nvim_pipe)
    (nnn data nil)
    (let [scope (fs/create-temp-dir {:prefix "nnn-pick-"})
          selection-file (str scope "/selection.txt")]
      (try
        (nnn data selection-file)
        (doseq [file (str/split-lines (slurp selection-file))]
          @(process "nvim" "--server" nvim_pipe "--remote" file))
        (finally (fs/delete-tree scope))))))
