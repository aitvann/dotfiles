#! /usr/bin/env bb
; vim: set ft=clojure:

(require
 '[hypr-current-location :refer [get-data]]
 '[babashka.process :refer [process]]
 '[cheshire.core :as json]
 '[clojure.java.io :as io]
 '[babashka.fs :as fs]
 '[clojure.string :as str])

(def active-workspace-task (process "hyprctl" "activeworkspace" "-j"))
(def clients-task (process "hyprctl" "clients" "-j"))

(import 'java.lang.ProcessHandle)
(defn sig-term [pid]
  (when-let [handle (-> (ProcessHandle/of (long pid))
                        (.orElse nil))]
    (.destroy handle)))

(defn kill-current-and-exit [& titles]
  (let [workspace-id
        (-> active-workspace-task
            :out
            io/reader
            (json/parse-stream true)
            :id)
        file-manager-pids
        (->> clients-task
             :out
             io/reader
             ((fn [x] (json/parse-stream x true)))
             (filter (fn [{:keys [workspace]}] (= workspace-id (:id workspace))))
             (filter (fn [{:keys [title floating]}] (and floating (some #(= % title) titles))))
             (map #(:pid %)))]
    (when (seq file-manager-pids)
      (doseq [pid file-manager-pids]
        (sig-term pid))
      (System/exit 0))))

